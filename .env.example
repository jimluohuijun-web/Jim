# 云酥记 Yun Su Ji environment example
# 复制为 .env.local 后，可按部署域名补充 NEXT_PUBLIC_SITE_URL。
# 预约表单会提交到 /api/reservations：
# - 未配置 Airtable 变量时，自动使用 mock fallback，便于本地开发和预览构建。
# - 配置 Airtable 变量后，服务端会写入 Airtable。不要把真实密钥提交到 Git。

NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_BRAND_NAME=云酥记
NEXT_PUBLIC_RESERVATION_MODE=airtable

# Airtable reservation intake. Do not commit real secrets.
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE_NAME=Reservations

# Future optional integrations. Do not commit real secrets.
SUPABASE_URL=
SUPABASE_ANON_KEY=
